# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord User ID (bot will only respond to this user)
# Optional: leave unset to let everyone in the channel use the bot
ALLOWED_USER_ID=your_discord_user_id

# Base folder path where Claude Code will operate
# Channel names will be appended to this path
BASE_FOLDER=/Users/your-user-name/repos

# Port for the MCP permission server (optional, default: 3001)
# Claude Code connects to http://localhost:<port>/mcp for tool approvals
#MCP_SERVER_PORT=3001

# Seconds to wait for a Discord approval reaction (optional, default: 30)
#MCP_APPROVAL_TIMEOUT=30

# What to do when an approval times out: allow or deny (optional, default: deny)
#MCP_DEFAULT_ON_TIMEOUT=deny